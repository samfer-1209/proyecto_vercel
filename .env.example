DJANGO_SECRET_KEY=tu_clave_secreta_aqui
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Firebase - conserva valores públicos del cliente (apiKey, projectId, appId)
FIREBASE_PROJECT_ID=proyecto-luna-xxxxx
FIREBASE_API_KEY=AIzaSy..._xxxxx
FIREBASE_AUTH_DOMAIN=proyecto-luna-xxxxx.firebaseapp.com
FIREBASE_STORAGE_BUCKET=proyecto-luna-xxxxx.appspot.com
FIREBASE_MESSAGING_SENDER_ID=###########
FIREBASE_APP_ID=1:#########:web:########

# Opciones para la cuenta de servicio (elige una):
# 1) Guardar el JSON en la raíz como firebase_service_account.json
# 2) Pegar el JSON compactado en FIREBASE_SERVICE_ACCOUNT_JSON
# Ejemplo (no incluir la clave real en el repo):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# No pongas claves privadas en el repositorio. Usa secretos en CI/prod.
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ... }
FIREBASE_API_KEY=your-firebase-api-key
